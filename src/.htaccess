# Verzeichnis-Listings deaktivieren
Options -Indexes

# Custom Error Pages (Pfade ohne führenden Schrägstrich testen)
ErrorDocument 400 /errors/400.html
ErrorDocument 401 /errors/401.html
ErrorDocument 403 /errors/403.html
ErrorDocument 404 /errors/404.html
ErrorDocument 500 /errors/500.html
ErrorDocument 503 /errors/503.html

# config/ und .env niemals ausliefern
<FilesMatch "(\.env|\.env\.example|waitlist\.csv)$">
    Require all denied
</FilesMatch>